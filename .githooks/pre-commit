#!/bin/bash
# Pre-commit hook: CI checks on main only.
# Auto-installed via: "prepare": "git config core.hooksPath .githooks"

branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$branch" != "main" ]; then
  exit 0
fi

echo "Committing to main — running checks..."

echo "→ turbo check && turbo test"
turbo check && turbo test || exit 1

if [ -d ".changeset" ]; then
  echo "→ changeset status"
  bunx changeset status --since=HEAD~1 || {
    echo "Missing changeset. Run 'bunx changeset' to add one."
    exit 1
  }
fi
